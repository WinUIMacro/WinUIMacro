<?xml version="1.0" encoding="utf-8"?>
<Window
  x:Class="WinUIMacro.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="WinUIMacro"
>
  <Window.SystemBackdrop>
    <MicaBackdrop />
  </Window.SystemBackdrop>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TitleBar x:Name="AppTitleBar" Title="WinUIMacro" />

    <SelectorBar
      x:Name="RootSelectorBar"
      Grid.Row="1"
      Margin="20,0,20,4"
      SelectionChanged="RootSelectorBar_SelectionChanged"
    >
      <SelectorBarItem x:Name="MacroListSelectorItem" Text="宏列表" Tag="Macros" />
      <SelectorBarItem x:Name="BindingsSelectorItem" Text="触发键绑定" Tag="Bindings" />
    </SelectorBar>

    <Grid
      x:Name="BackBar"
      Grid.Row="1"
      Visibility="Collapsed"
      MinHeight="56"
      Padding="12,4,16,6"
      RowSpacing="2"
      DataContext="{x:Bind ViewModel.SelectedMacro, Mode=OneWay}"
    >
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="60" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="88" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Button
        Grid.Row="1"
        Width="40"
        Height="40"
        HorizontalAlignment="Left"
        VerticalAlignment="Center"
        Click="BackButton_Click"
      >
        <SymbolIcon Symbol="Back" />
      </Button>
      <TextBlock Grid.Column="2" Text="名称" FontSize="12" Opacity="0.7" />
      <TextBlock Grid.Column="4" Text="总延迟" FontSize="12" Opacity="0.7" />
      <TextBlock Grid.Column="6" Text="运行方式" FontSize="12" Opacity="0.7" />
      <TextBox
        Grid.Row="1"
        Grid.Column="2"
        Width="120"
        Height="32"
        VerticalAlignment="Center"
        AcceptsReturn="False"
        MaxLength="64"
        TextWrapping="NoWrap"
        Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
      />
      <TextBlock
        Grid.Row="1"
        Grid.Column="4"
        VerticalAlignment="Center"
        Text="{Binding TotalDurationDisplay}"
        FontWeight="SemiBold"
      />
      <ComboBox
        Grid.Row="1"
        Grid.Column="6"
        Width="88"
        Height="32"
        VerticalAlignment="Center"
        SelectedIndex="{Binding ModeIndex, Mode=TwoWay}"
      >
        <ComboBoxItem Content="一次" />
        <ComboBoxItem Content="切换" />
        <ComboBoxItem Content="按住" />
      </ComboBox>
      <CommandBar
        Grid.Row="1"
        Grid.Column="8"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Background="Transparent"
        DefaultLabelPosition="Right"
        IsDynamicOverflowEnabled="False"
      >
        <AppBarButton
          Icon="Delete"
          Label="删除"
          Click="DeleteMacro_Click"
          IsEnabled="{x:Bind ViewModel.CanEditSequence, Mode=OneWay}"
        />
        <AppBarButton
          Icon="Save"
          Label="保存"
          Command="{x:Bind ViewModel.SaveMacroCommand}"
          IsEnabled="{x:Bind ViewModel.CanEditSequence, Mode=OneWay}"
        />
        <AppBarButton
          x:Name="RecordButton"
          Label="{x:Bind ViewModel.RecordButtonLabel, Mode=OneWay}"
          Click="RecordButton_Click"
          SizeChanged="RecordButton_SizeChanged"
        >
          <AppBarButton.Icon>
            <FontIcon Glyph="{x:Bind ViewModel.RecordButtonGlyph, Mode=OneWay}" />
          </AppBarButton.Icon>
        </AppBarButton>
        <AppBarSeparator />
        <AppBarButton
          Icon="Clock"
          Label="延迟"
          Command="{x:Bind ViewModel.AddDelayCommand}"
          IsEnabled="{x:Bind ViewModel.CanEditSequence, Mode=OneWay}"
        />
        <AppBarButton
          Icon="Edit"
          Label="注释"
          Command="{x:Bind ViewModel.AddNoteCommand}"
          IsEnabled="{x:Bind ViewModel.CanEditSequence, Mode=OneWay}"
        />
      </CommandBar>
    </Grid>

    <ContentControl
      x:Name="ContentHost"
      Grid.Row="2"
      HorizontalContentAlignment="Stretch"
      VerticalContentAlignment="Stretch"
    />

    <InfoBar
      Grid.RowSpan="3"
      Margin="16"
      MaxWidth="760"
      HorizontalAlignment="Right"
      VerticalAlignment="Bottom"
      IsClosable="True"
      IsOpen="{x:Bind ViewModel.IsMessageOpen, Mode=TwoWay}"
      Severity="{x:Bind ViewModel.MessageSeverity, Mode=OneWay}"
    >
      <TextBlock
        MaxWidth="680"
        IsTextSelectionEnabled="True"
        Text="{x:Bind ViewModel.Message, Mode=OneWay}"
        TextWrapping="Wrap"
      />
    </InfoBar>
  </Grid>
</Window>
