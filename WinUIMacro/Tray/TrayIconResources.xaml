<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:tb="using:H.NotifyIcon"
>
  <XamlUICommand x:Key="OpenMainWindowCommand" Label="打开主窗口" Description="打开主窗口">
    <XamlUICommand.IconSource>
      <SymbolIconSource Symbol="OpenPane" />
    </XamlUICommand.IconSource>
  </XamlUICommand>

  <XamlUICommand x:Key="ExitApplicationCommand" Label="退出" Description="退出应用程序">
    <XamlUICommand.IconSource>
      <SymbolIconSource Symbol="Cancel" />
    </XamlUICommand.IconSource>
  </XamlUICommand>

  <tb:TaskbarIcon
    x:Key="ApplicationTrayIcon"
    Visibility="Visible"
    ToolTipText="WinUIMacro"
    IconSource="\Assets\TrayIcon.ico"
    DoubleClickCommand="{StaticResource OpenMainWindowCommand}"
    ContextMenuMode="PopupMenu"
  >
    <tb:TaskbarIcon.ContextFlyout>
      <MenuFlyout>
        <MenuFlyoutItem Command="{StaticResource OpenMainWindowCommand}" />

        <MenuFlyoutSeparator />

        <MenuFlyoutItem Command="{StaticResource ExitApplicationCommand}" />
      </MenuFlyout>
    </tb:TaskbarIcon.ContextFlyout>
  </tb:TaskbarIcon>
</ResourceDictionary>
