<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Default">
      <SolidColorBrush x:Key="MacroKeyboardBrush" Color="#0F6CBD" />
      <SolidColorBrush x:Key="MacroMouseBrush" Color="#007A5A" />
      <SolidColorBrush x:Key="MacroWheelBrush" Color="#8A5A00" />
      <SolidColorBrush x:Key="MacroDelayBrush" Color="#5B3BB2" />
      <SolidColorBrush x:Key="MacroNoteBrush" Color="#5E5E5E" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="MacroKeyboardBrush" Color="#0F6CBD" />
      <SolidColorBrush x:Key="MacroMouseBrush" Color="#007A5A" />
      <SolidColorBrush x:Key="MacroWheelBrush" Color="#8A5A00" />
      <SolidColorBrush x:Key="MacroDelayBrush" Color="#5B3BB2" />
      <SolidColorBrush x:Key="MacroNoteBrush" Color="#5E5E5E" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="MacroKeyboardBrush" Color="#60AFFF" />
      <SolidColorBrush x:Key="MacroMouseBrush" Color="#42C7A5" />
      <SolidColorBrush x:Key="MacroWheelBrush" Color="#F2C14E" />
      <SolidColorBrush x:Key="MacroDelayBrush" Color="#C7B8FF" />
      <SolidColorBrush x:Key="MacroNoteBrush" Color="#D0D0D0" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="HighContrast">
      <SolidColorBrush
        x:Key="MacroKeyboardBrush"
        Color="{ThemeResource SystemColorHighlightColor}"
      />
      <SolidColorBrush x:Key="MacroMouseBrush" Color="{ThemeResource SystemColorHighlightColor}" />
      <SolidColorBrush x:Key="MacroWheelBrush" Color="{ThemeResource SystemColorHighlightColor}" />
      <SolidColorBrush x:Key="MacroDelayBrush" Color="{ThemeResource SystemColorHighlightColor}" />
      <SolidColorBrush x:Key="MacroNoteBrush" Color="{ThemeResource SystemColorHighlightColor}" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
