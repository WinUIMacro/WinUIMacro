<?xml version="1.0" encoding="utf-8"?>
<Page
  x:Class="WinUIMacro.Views.BindingsPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:WinUIMacro.ViewModels"
>
  <Page.Resources>
    <DataTemplate x:Key="BindingKeyTemplate">
      <Button
        Height="48"
        MinWidth="44"
        Padding="0"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        Click="Key_Click"
        Tag="{Binding}"
      >
        <Grid>
          <Border
            Background="{ThemeResource AccentFillColorDefaultBrush}"
            CornerRadius="4"
            Opacity="{Binding BoundBackgroundOpacity}"
          />
          <Grid Padding="4" RowSpacing="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              FontWeight="SemiBold"
              Text="{Binding DisplayText}"
              TextTrimming="CharacterEllipsis"
            />
            <TextBlock
              Grid.Row="1"
              HorizontalAlignment="Center"
              FontSize="10"
              Opacity="0.7"
              Text="{Binding BoundMacroName}"
              TextTrimming="CharacterEllipsis"
            />
          </Grid>
        </Grid>
      </Button>
    </DataTemplate>
  </Page.Resources>
  <Grid Padding="24" RowSpacing="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <TextBlock Text="触发键绑定" FontSize="24" FontWeight="SemiBold" />
    <ScrollViewer
      x:Name="BindingScroll"
      Grid.Row="1"
      HorizontalScrollMode="Enabled"
      HorizontalScrollBarVisibility="Auto"
      VerticalScrollBarVisibility="Auto"
      SizeChanged="BindingScroll_SizeChanged"
    >
      <Grid x:Name="BindingSurface" MinWidth="1280" ColumnSpacing="28" RowSpacing="18">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition x:Name="MouseColumn" Width="220" />
          <ColumnDefinition x:Name="KeyboardColumn" Width="*" />
        </Grid.ColumnDefinitions>
        <Grid x:Name="MousePanel" Height="336">
          <Border
            Width="132"
            Height="292"
            Margin="60,18,0,0"
            HorizontalAlignment="Left"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="72,72,46,46"
          />
          <ItemsControl
            x:Name="MouseSideKeysList"
            Width="112"
            Margin="22,118,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ItemsSource="{x:Bind ViewModel.MouseSideKeys, Mode=OneWay}"
            ItemTemplate="{StaticResource BindingKeyTemplate}"
          >
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="10" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </Grid>
        <Grid
          x:Name="KeyboardGrid"
          Grid.Column="1"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Top"
          ColumnSpacing="4"
          RowSpacing="4"
        />
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
