<?xml version="1.0" encoding="utf-8"?>
<!-- 宏详情页面：名称、播放方式、节点编辑和录制操作。 -->
<Page
  x:Class="WinUIMacro.UI.Views.MacroDetailPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:WinUIMacro.UI.ViewModels"
>
  <Grid Padding="22">
    <GridView
      x:Name="NodeGrid"
      ItemsSource="{x:Bind Macro.Nodes, Mode=OneWay}"
      AllowDrop="{x:Bind ViewModel.CanEditSequence, Mode=OneWay}"
      CanDragItems="{x:Bind ViewModel.CanEditSequence, Mode=OneWay}"
      CanReorderItems="{x:Bind ViewModel.CanEditSequence, Mode=OneWay}"
      SelectionMode="Single"
      KeyDown="NodeGrid_KeyDown"
      PointerWheelChanged="NodeGrid_PointerWheelChanged"
    >
      <GridView.ItemsPanel>
        <ItemsPanelTemplate>
          <ItemsWrapGrid Orientation="Horizontal" />
        </ItemsPanelTemplate>
      </GridView.ItemsPanel>
      <GridView.ItemContainerStyle>
        <Style TargetType="GridViewItem">
          <Setter Property="Width" Value="96" />
          <Setter Property="Height" Value="96" />
          <Setter Property="Margin" Value="0,0,8,8" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
      </GridView.ItemContainerStyle>
      <GridView.ItemTemplate>
        <DataTemplate x:DataType="vm:MacroNodeViewModel">
          <Border
            Padding="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ToolTipService.ToolTip="{x:Bind DisplayText, Mode=OneWay}"
          >
            <Grid>
              <Grid RowSpacing="2" Visibility="{x:Bind IsKeyboard}">
                <Grid.RowDefinitions>
                  <RowDefinition Height="14" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="14" />
                </Grid.RowDefinitions>
                <Path
                  Width="16"
                  Height="12"
                  HorizontalAlignment="Center"
                  Data="M8,0 L16,11 L0,11 Z"
                  Fill="{ThemeResource MacroKeyboardBrush}"
                  Visibility="{x:Bind ReleaseVisibility}"
                />
                <Border
                  Grid.Row="1"
                  MinWidth="48"
                  Padding="8,5"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                  BorderBrush="{ThemeResource MacroKeyboardBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                >
                  <TextBlock
                    Text="{x:Bind DisplayText}"
                    Foreground="{ThemeResource MacroKeyboardBrush}"
                    FontWeight="SemiBold"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords"
                  />
                </Border>
                <Path
                  Grid.Row="2"
                  Width="16"
                  Height="12"
                  HorizontalAlignment="Center"
                  Data="M0,0 L16,0 L8,11 Z"
                  Fill="{ThemeResource MacroKeyboardBrush}"
                  Visibility="{x:Bind PressVisibility}"
                />
              </Grid>
              <Grid RowSpacing="2" Visibility="{x:Bind IsMouseButton}">
                <Grid.RowDefinitions>
                  <RowDefinition Height="14" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="14" />
                </Grid.RowDefinitions>
                <Path
                  Width="16"
                  Height="12"
                  HorizontalAlignment="Center"
                  Data="M8,0 L16,11 L0,11 Z"
                  Fill="{ThemeResource MacroMouseBrush}"
                  Visibility="{x:Bind ReleaseVisibility}"
                />
                <Viewbox Grid.Row="1" Stretch="Uniform">
                  <Grid Width="42" Height="54">
                    <Canvas Width="42" Height="54" Visibility="{x:Bind MouseTopVisibility}">
                      <Path
                        Data="M21,2 C11,2 5,10 5,21 L5,34 C5,45 11,52 21,52 C31,52 37,45 37,34 L37,21 C37,10 31,2 21,2 Z"
                        Fill="Transparent"
                        Stroke="{ThemeResource MacroMouseBrush}"
                        StrokeThickness="1.6"
                      />
                      <Line
                        X1="21"
                        X2="21"
                        Y1="4"
                        Y2="23"
                        Stroke="{ThemeResource MacroMouseBrush}"
                      />
                      <Path
                        Data="M19,5 C12,6 8,12 8,21 L8,23 L19,23 Z"
                        Fill="{ThemeResource MacroMouseBrush}"
                        Visibility="{x:Bind MouseLeftVisibility}"
                      />
                      <Path
                        Data="M23,5 C30,6 34,12 34,21 L34,23 L23,23 Z"
                        Fill="{ThemeResource MacroMouseBrush}"
                        Visibility="{x:Bind MouseRightVisibility}"
                      />
                      <Rectangle
                        Canvas.Left="18"
                        Canvas.Top="6"
                        Width="6"
                        Height="12"
                        Fill="{ThemeResource MacroMouseBrush}"
                        RadiusX="3"
                        RadiusY="3"
                        Visibility="{x:Bind MouseMiddleVisibility}"
                      />
                    </Canvas>
                    <Canvas Width="42" Height="54" Visibility="{x:Bind MouseSideVisibility}">
                      <Path
                        Data="M14,2 L21,2 C29,2 36,13 38,25 C40,39 32,50 22,52 L14,52 C11,52 9,50 9,47 L9,7 C9,4 11,2 14,2 Z"
                        Fill="Transparent"
                        Stroke="{ThemeResource MacroMouseBrush}"
                        StrokeThickness="1.6"
                      />
                      <Rectangle
                        Canvas.Left="14"
                        Canvas.Top="16"
                        Width="9"
                        Height="14"
                        Fill="{ThemeResource MacroMouseBrush}"
                        RadiusX="3.5"
                        RadiusY="3.5"
                        Visibility="{x:Bind MouseX2Visibility}"
                      />
                      <Rectangle
                        Canvas.Left="14"
                        Canvas.Top="33"
                        Width="9"
                        Height="14"
                        Fill="{ThemeResource MacroMouseBrush}"
                        RadiusX="3.5"
                        RadiusY="3.5"
                        Visibility="{x:Bind MouseX1Visibility}"
                      />
                    </Canvas>
                  </Grid>
                </Viewbox>
                <Path
                  Grid.Row="2"
                  Width="16"
                  Height="12"
                  HorizontalAlignment="Center"
                  Data="M0,0 L16,0 L8,11 Z"
                  Fill="{ThemeResource MacroMouseBrush}"
                  Visibility="{x:Bind PressVisibility}"
                />
              </Grid>
              <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="4"
                Visibility="{x:Bind IsMouseWheel}"
              >
                <FontIcon
                  Glyph="&#xE962;"
                  FontSize="28"
                  Foreground="{ThemeResource MacroWheelBrush}"
                />
                <TextBlock
                  Text="{x:Bind WheelArrow}"
                  FontSize="24"
                  FontWeight="SemiBold"
                  Foreground="{ThemeResource MacroWheelBrush}"
                  HorizontalAlignment="Center"
                />
              </StackPanel>
              <Grid Visibility="{x:Bind IsDelay}">
                <TextBlock
                  Tag="{x:Bind}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  FontWeight="SemiBold"
                  Foreground="{ThemeResource MacroDelayBrush}"
                  Text="{x:Bind DisplayText, Mode=OneWay}"
                  TextAlignment="Center"
                  Tapped="EditableNodeDisplay_Tapped"
                  Visibility="{x:Bind DisplayVisibility, Mode=OneWay}"
                />
                <TextBox
                  Tag="{x:Bind}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  HorizontalContentAlignment="Center"
                  MaxLength="19"
                  Text="{x:Bind EditableValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  BeforeTextChanging="Delay_BeforeTextChanging"
                  KeyDown="EditableNodeTextBox_KeyDown"
                  LostFocus="EditableNodeTextBox_LostFocus"
                  Visibility="{x:Bind EditVisibility, Mode=OneWay}"
                />
              </Grid>
              <Grid Visibility="{x:Bind IsNote}">
                <TextBlock
                  Tag="{x:Bind}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Foreground="{ThemeResource MacroNoteBrush}"
                  MaxLines="3"
                  Text="{x:Bind DisplayText, Mode=OneWay}"
                  TextAlignment="Center"
                  TextWrapping="WrapWholeWords"
                  Tapped="EditableNodeDisplay_Tapped"
                  Visibility="{x:Bind DisplayVisibility, Mode=OneWay}"
                />
                <TextBox
                  Tag="{x:Bind}"
                  VerticalAlignment="Center"
                  TextAlignment="Center"
                  TextWrapping="Wrap"
                  MaxLength="160"
                  Text="{x:Bind EditableValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  KeyDown="EditableNodeTextBox_KeyDown"
                  LostFocus="EditableNodeTextBox_LostFocus"
                  Visibility="{x:Bind EditVisibility, Mode=OneWay}"
                />
              </Grid>
            </Grid>
          </Border>
        </DataTemplate>
      </GridView.ItemTemplate>
    </GridView>
  </Grid>
</Page>
