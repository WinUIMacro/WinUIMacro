<?xml version="1.0" encoding="utf-8"?>
<!-- 宏列表页面：宏展示、新建入口和空状态。 -->
<Page
  x:Class="WinUIMacro.UI.Views.MacroListPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:WinUIMacro.UI.ViewModels"
>
  <Grid Padding="24" RowSpacing="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid ColumnSpacing="16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Text="宏列表" FontSize="24" FontWeight="SemiBold" />
      <StackPanel
        Grid.Column="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Orientation="Horizontal"
        Spacing="8"
      >
        <Button Command="{x:Bind ViewModel.OpenMacroFolderCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <SymbolIcon Symbol="OpenFile" />
            <TextBlock Text="打开文件夹" />
          </StackPanel>
        </Button>
        <Button Command="{x:Bind ViewModel.RefreshMacrosCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <SymbolIcon Symbol="Refresh" />
            <TextBlock Text="刷新" />
          </StackPanel>
        </Button>
        <Button
          Click="AddMacro_Click"
          IsEnabled="{x:Bind ViewModel.CanChangeWorkspace, Mode=OneWay}"
        >
          <StackPanel Orientation="Horizontal" Spacing="8">
            <SymbolIcon Symbol="Add" />
            <TextBlock Text="新建宏" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>
    <GridView
      x:Name="MacroGrid"
      Grid.Row="1"
      ItemsSource="{x:Bind ViewModel.Macros, Mode=OneWay}"
      SelectionMode="None"
      IsItemClickEnabled="True"
      IsEnabled="{x:Bind ViewModel.CanChangeWorkspace, Mode=OneWay}"
      ItemClick="MacroGrid_ItemClick"
    >
      <GridView.ItemContainerStyle>
        <Style TargetType="GridViewItem">
          <Setter Property="Width" Value="260" />
          <Setter Property="MaxWidth" Value="260" />
          <Setter Property="MinHeight" Value="76" />
          <Setter Property="Margin" Value="0,0,12,12" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
      </GridView.ItemContainerStyle>
      <GridView.ItemTemplate>
        <DataTemplate x:DataType="vm:MacroEditorViewModel">
          <Border
            MinHeight="76"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
          >
            <Grid>
              <Border
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="8"
                Opacity="{x:Bind BoundBackgroundOpacity, Mode=OneWay}"
              />
              <StackPanel Margin="12" VerticalAlignment="Center" Spacing="6">
                <TextBlock
                  FontWeight="SemiBold"
                  Text="{x:Bind DisplayName, Mode=OneWay}"
                  TextAlignment="Center"
                  TextTrimming="CharacterEllipsis"
                />
                <TextBlock
                  Text="{x:Bind BindingSummary, Mode=OneWay}"
                  TextAlignment="Center"
                  Opacity="0.7"
                  TextTrimming="CharacterEllipsis"
                />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </GridView.ItemTemplate>
    </GridView>
  </Grid>
</Page>
