<?xml version="1.0" encoding="utf-8"?>
<Page
  x:Class="WinUIMacro.UI.Views.BindingsPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:WinUIMacro.UI.ViewModels"
>
  <Page.Resources>
    <Flyout x:Name="BindingFlyout" Closed="BindingFlyout_Closed">
      <StackPanel Width="280" Padding="4" Spacing="8">
        <Button
          x:Name="UnbindButton"
          HorizontalAlignment="Stretch"
          Click="Unbind_Click"
          Content="取消绑定"
        />
        <AutoSuggestBox
          x:Name="SearchBox"
          PlaceholderText="搜索宏"
          TextChanged="SearchBox_TextChanged"
        >
          <AutoSuggestBox.QueryIcon>
            <SymbolIcon Symbol="Find" />
          </AutoSuggestBox.QueryIcon>
        </AutoSuggestBox>
        <ListView
          x:Name="CandidateList"
          MaxHeight="320"
          DisplayMemberPath="Name"
          IsItemClickEnabled="True"
          ItemClick="CandidateList_ItemClick"
          SelectionMode="None"
        />
      </StackPanel>
    </Flyout>
    <DataTemplate x:Key="BindingKeyTemplate">
      <Border
        Height="48"
        MinWidth="44"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        CornerRadius="4"
      >
        <Grid>
          <Border
            Background="{ThemeResource AccentFillColorDefaultBrush}"
            CornerRadius="4"
            Opacity="{Binding BoundBackgroundOpacity}"
          />
          <Button
            Padding="4"
            Background="Transparent"
            BorderThickness="0"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Click="Key_Click"
            Tag="{Binding}"
          >
            <Grid RowSpacing="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="{Binding DisplayText}"
                TextTrimming="CharacterEllipsis"
              />
              <TextBlock
                Grid.Row="1"
                HorizontalAlignment="Center"
                FontSize="10"
                Opacity="0.7"
                Text="{Binding BoundMacroName}"
                TextTrimming="CharacterEllipsis"
              />
            </Grid>
          </Button>
        </Grid>
      </Border>
    </DataTemplate>
  </Page.Resources>
  <Grid Padding="24" RowSpacing="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <TextBlock Text="触发键绑定" FontSize="24" FontWeight="SemiBold" />
    <ScrollViewer
      x:Name="BindingScroll"
      Grid.Row="1"
      HorizontalScrollMode="Enabled"
      HorizontalScrollBarVisibility="Auto"
      VerticalScrollBarVisibility="Auto"
      SizeChanged="BindingScroll_SizeChanged"
    >
      <Grid x:Name="BindingSurface" MinWidth="1160" ColumnSpacing="20" RowSpacing="18">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition x:Name="KeyboardColumn" Width="*" />
          <ColumnDefinition x:Name="MouseColumn" Width="160" />
        </Grid.ColumnDefinitions>
        <Grid
          x:Name="KeyboardGrid"
          Grid.Column="0"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Top"
          ColumnSpacing="4"
          RowSpacing="4"
        />
        <Grid x:Name="MousePanel" Grid.Column="1" Height="252">
          <Border
            Width="96"
            Height="220"
            Margin="48,12,0,0"
            HorizontalAlignment="Left"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="52,52,34,34"
          />
          <ItemsControl
            x:Name="MouseSideKeysList"
            Width="72"
            Margin="8,78,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ItemsSource="{x:Bind ViewModel.MouseSideKeys, Mode=OneWay}"
            ItemTemplate="{StaticResource BindingKeyTemplate}"
          >
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </Grid>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
